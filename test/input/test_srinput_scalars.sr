// Positive test: scalar constants inside srinput blocks.
// Tests all three qualifier forms: "static const", "const", and no qualifier.
// Tests a variety of scalar types from g_Scalars.

cbuffer FrameConsts
{
    float4x4 m_ViewProj;
    float    m_Time;
};

srinput ScalarTestInputs
{
    FrameConsts m_Frame;

    // No qualifier
    float       MaxDistance = 1000.0;
    uint        MaxLights   = 16;
    int         DebugMode   = 0;

    // "const" qualifier
    const float Pi          = 3.14159;
    const uint  Version     = 2;

    // "static const" qualifier
    static const float  Epsilon     = 0.0001;
    static const int    MaxBounces  = 8;
    static const uint32_t Flags     = 255;
    static const int32_t  NegOne    = -1;
    static const uint16_t SmallVal  = 4;
    static const int16_t  SignedSmall = -10;
    static const float16_t HalfVal  = 1;
    static const double    BigPi    = 3.14159265358979;
    static const bool      Enabled  = true;
};
