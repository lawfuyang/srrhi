// 4. With semantic names + comments + mixed layout
cbuffer SceneConstants
{
    /* Camera matrices */
    float4x4 view;
    float4x4 proj;
    float4x4 viewProj;
    float4x4 invViewProj;

    float3  cameraPosWS;
    float   exposure;

    /* Fog / atmosphere */
    float4  fogParams;        // x = start, y = end, z = density, w = height falloff
    float4  fogColor;

    /* Misc */
    uint    frameNumber;
    float   deltaTime;
    float   pad0[2];            // explicit padding test
};

srinput MainInputs
{
    SceneConstants scene;
};
