// EXPECTED TO FAIL: name clash between inherited scalar const and a body scalar const.
// Base has 'MaxLights'; Derived body also declares 'MaxLights' -- name clash.

srinput Base
{
    static const uint MaxLights = 16;
};

srinput Derived : Base
